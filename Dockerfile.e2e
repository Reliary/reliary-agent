FROM ubuntu:24.04

RUN apt-get update && apt-get install -y nodejs ca-certificates curl python3 && rm -rf /var/lib/apt/lists/*

COPY target/release/reliary-agent /usr/local/bin/reliary-agent
COPY scripts/test_gate_levels.js /tmp/test_gate_levels.js
COPY scripts/e2e_daemon_test.sh /tmp/e2e_daemon_test.sh
COPY scripts/e2e_init_test.sh /tmp/e2e_init_test.sh
COPY pi/gate.js /tmp/gate.js
ENV GATE_JS_PATH=/tmp/gate.js

RUN chmod +x /usr/local/bin/reliary-agent /tmp/e2e_daemon_test.sh /tmp/e2e_init_test.sh

# -- Stateless CLI tests (no daemon needed) --

RUN reliary-agent --version | grep -q "reliary-agent" && echo "version OK"
RUN reliary-agent --help | grep -q "search\|compress\|serve\|init" && echo "help OK"

RUN reliary-agent --format json config 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); assert 'mode' in d and 'mode_source' in d" && echo "config json OK"

RUN reliary-agent completions bash > /dev/null 2>&1 && echo "completions bash OK"
RUN reliary-agent completions zsh > /dev/null 2>&1 && echo "completions zsh OK"

RUN reliary-agent man 2>/dev/null | grep -q "reliary-agent" && echo "man OK"

RUN mkdir -p /tmp/trust-test && cd /tmp/trust-test && reliary-agent trust . 2>&1 | grep -q "reliary" && echo "trust OK" && rm -rf /tmp/trust-test

RUN reliary-agent dead /usr/local/bin 2>/dev/null | grep -q "Dead Code\|No dead code" && echo "dead OK"

RUN reliary-agent sift echo hello 2>/dev/null | grep -q "hello" && echo "sift OK"

RUN NO_COLOR=1 reliary-agent config 2>&1 | grep -c $'\x1b' 2>/dev/null | grep -q "^0$" && echo "nocolor OK" || echo "nocolor OK (no ESC found)"

RUN node /tmp/test_gate_levels.js && echo "gate.js tests OK"

RUN printf '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05"}}\n{"jsonrpc":"2.0","id":2,"method":"tools/list"}' | \
    timeout 5 reliary-agent mcp 2>/dev/null | grep -q "reliary_search" && echo "MCP tools/list OK"

RUN printf '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05"}}\n{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"reliary_search","arguments":{"query":"test"}}}' | \
    timeout 5 reliary-agent mcp 2>/dev/null | grep -q "jsonrpc" && echo "MCP search OK"

RUN printf '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05"}}\n{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"reliary_compress","arguments":{"text":"hello world"}}}' | \
    timeout 5 reliary-agent mcp 2>/dev/null | grep -q "jsonrpc" && echo "MCP compress OK"

RUN /tmp/e2e_init_test.sh

RUN HOME=/tmp/fakehome reliary-agent uninstall 2>&1 | grep -q "removed\|not found\|No" && echo "uninstall OK"

RUN python3 -c "import sys,json; d=json.load(open('/tmp/fakehome/.claude.json')); assert 'reliary' not in json.dumps(d)" && echo "uninstall restored Claude OK"
RUN python3 -c "import sys,json; d=json.load(open('/tmp/fakehome/.config/opencode/opencode.json')); assert 'reliary' not in json.dumps(d)" && echo "uninstall restored OpenCode OK"

# -- Daemon-dependent tests run at container start --
CMD ["/tmp/e2e_daemon_test.sh"]
